<style>
    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

/* Body Styling */
body {
    background-color: #f0f2f5; /* Màu nền xám nhạt */
}

/* Header Section */
#header {
    background-color: #000;
    color: #fff;
    padding: 10px 0;
}

.main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
}

.logo {
    display: flex;
    align-items: center;
    text-decoration: none;
}

.logo h1 {
    color: #fff;
    font-size: 42px;
    font-weight: bold;
}

#navbar {
    display: flex;
    list-style: none;
    align-items: center;
}

#navbar li {
    margin-left: 20px;
}

#navbar li a {
    color: #fff;
    text-decoration: none;
    font-size: 16px;
}

#navbar li a:hover {
    color: #ccc;
}

/* Notification Styling */
.notification {
    position: relative;
    display: inline-block;
}

.notification .notification-count {
    background-color: #ff6347;
    color: #fff;
    border-radius: 50%;
    padding: 2px 6px;
    font-size: 12px;
    position: relative;
    top: -5px;
    left: 2px;
}

.notification-content {
    display: none;
    position: absolute;
    background-color: #fff;
    min-width: 250px;
    box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.2);
    z-index: 1;
    top: 30px;
    right: 0;
    padding: 10px;
}

.notification:hover .notification-content {
    display: block;
}

.notification-content p {
    color: #333;
    font-size: 14px;
    margin-bottom: 10px;
}

.notification-content a {
    color: #ff6347;
    text-decoration: none;
    font-size: 14px;
    display: block;
    text-align: center;
}

.notification-content a:hover {
    text-decoration: underline;
}

/* User Info (Hello: Admin) */
.user-info {
    display: flex;
    align-items: center;
    font-size: 16px;
    color: #fff;
}

.user-info i {
    margin-right: 5px;
}

/* Hamburger Menu */
.hamburger {
    position: relative;
    font-size: 20px;
    color: #fff;
    cursor: pointer;
}

.hamburger-menu {
    display: none;
    position: absolute;
    top: 30px;
    right: 0;
    background-color: #f5f5f5;
    box-shadow: 0px 8px 16px 0px rgba(0, 0, 0, 0.2);
    z-index: 1;
    min-width: 150px;
    border-radius: 5px;
    overflow: visible;
}

.hamburger-menu.active {
    display: block;
}

.hamburger-menu a {
    display: block;
    padding: 10px 15px;
    color: #000;
    text-decoration: none;
    font-size: 14px;
    border-bottom: 1px solid #ddd;
}

.hamburger-menu a:last-child {
    border-bottom: none;
}

.hamburger-menu a:hover {
    background-color: #e0e0e0;
    color: #000;
}

/* Seller Dashboard Wrapper */
.seller-dashboard-wrapper {
    display: flex;
    margin-top: 0;
}

/* Sidebar */
.sidebar {
    width: 250px;
    background-color: #1a252f; /* Màu nền sidebar giống Shopee */
    color: #fff;
    min-height: calc(100vh - 70px);
}

.sidebar-menu {
    list-style: none;
    padding: 0;
    margin: 0;
}

.sidebar-menu .menu-item {
    font-size: 14px;
    cursor: pointer;
}

.sidebar-menu .menu-item-header {
    padding: 15px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background-color 0.3s ease;
}

.sidebar-menu .menu-item-header i:first-child {
    margin-right: 10px;
}

.sidebar-menu .menu-item-header:hover {
    background-color: #2c3e50; /* Màu khi hover */
}

.sidebar-menu .menu-item.active .menu-item-header {
    background-color: #3498db; /* Màu khi active */
}

.sidebar-menu .submenu {
    display: none;
    list-style: none;
    padding: 0;
    background-color: #2c3e50; /* Màu nền của sub-menu */
}

.sidebar-menu .submenu.active {
    display: block;
}

.sidebar-menu .submenu li {
    padding: 10px 20px 10px 40px; /* Thụt lề sub-menu */
}

.sidebar-menu .submenu li a {
    color: #fff;
    text-decoration: none;
    font-size: 13px;
}

.sidebar-menu .submenu li a:hover {
    color: #3498db; /* Màu chữ khi hover sub-menu */
}

.submenu-toggle {
    transition: transform 0.3s ease;
}

.submenu-toggle.active {
    transform: rotate(180deg); /* Xoay mũi tên khi sub-menu mở */
}

/* Main Content */
.main-content {
    flex: 1;
    padding: 20px;
    background-color: #f0f2f5;
}

/* Dashboard Container */
.section-p1 {
    padding: 40px 0;
}

.section-title {
    font-size: 28px;
    color: #ee4d2d;
    margin-bottom: 25px;
    text-transform: uppercase;
}

.dashboard-container {
    display: flex;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
    flex-wrap: wrap;
}

/* Add Product Form */
.add-product-form {
    flex: 1;
    background-color: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
}

.add-product-form h3 {
    font-size: 20px;
    color: #333;
    margin-bottom: 20px;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    font-size: 14px;
    color: #555;
    margin-bottom: 5px;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 14px;
    outline: none;
}

.form-group textarea {
    height: 100px;
    resize: vertical;
}

.submit-btn {
    width: 100%;
    padding: 12px;
    background-color: #e74c3c;
    color: #fff;
    border: none;
    border-radius: 5px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

.submit-btn:hover {
    background-color: #c0392b;
}

/* Product List */
.product-list {
    flex: 2;
    background-color: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
}

.product-list h3 {
    font-size: 20px;
    color: #333;
    margin-bottom: 20px;
}

#product-table {
    width: 100%;
    border-collapse: collapse;
}

#product-table th,
#product-table td {
    padding: 10px;
    text-align: left;
    border-bottom: 1px solid #ddd;
}

#product-table th {
    background-color: #f9f9f9;
    font-weight: bold;
    color: #333;
}

#product-table td img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 5px;
}

#product-table td {
    font-size: 14px;
    color: #555;
}

#product-table .action-btn {
    background-color: #e74c3c;
    color: #fff;
    border: none;
    padding: 5px 10px;
    border-radius: 5px;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

#product-table .action-btn:hover {
    background-color: #c0392b;
}

/* Chat Support */
.chat-support {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 1000;
}

.chat-icon {
    background-color: #ee4d2d;
    color: #fff;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    cursor: pointer;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    position: relative;
}

.chat-badge {
    position: absolute;
    top: -5px;
    right: -5px;
    background-color: #fff;
    color: #ee4d2d;
    font-size: 12px;
    font-weight: bold;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ee4d2d;
}

.chat-box {
    display: none;
    width: 300px;
    background-color: #fff;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    position: absolute;
    bottom: 70px;
    right: 0;
}

.chat-box.active {
    display: block;
}

.chat-header {
    background-color: #ee4d2d;
    color: #fff;
    padding: 10px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chat-header h4 {
    margin: 0;
    font-size: 16px;
}

.chat-header .close-chat {
    cursor: pointer;
}

.chat-body {
    padding: 15px;
    max-height: 200px;
    overflow-y: auto;
    border-bottom: 1px solid #ddd;
}

.chat-body p {
    margin: 0;
    font-size: 14px;
    color: #555;
}

.chat-footer {
    display: flex;
    padding: 10px;
    gap: 10px;
}

.chat-footer input {
    flex: 1;
    padding: 8px;
    border: 1px solid #ddd;
    border-radius: 5px;
    outline: none;
}

.chat-footer .send-message {
    background-color: #ee4d2d;
    color: #fff;
    border: none;
    padding: 8px 12px;
    border-radius: 5px;
    cursor: pointer;
}

.chat-footer .send-message:hover {
    background-color: #d43f21;
}

/* Footer Section */
#footer {
    background-color: #f1f1f1;
    padding: 50px 80px;
    border-top: 1px solid #ddd;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
}

.footer-container .col {
    flex: 1;
    min-width: 200px;
    margin-bottom: 20px;
}

.footer-container .col .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
}

.footer-container .col .logo img {
    width: 50px;
    height: 50px;
    margin-right: 10px;
}

.footer-container .col .logo h1 {
    color: #333;
    font-size: 24px;
    font-weight: bold;
}

.footer-container .col h4 {
    font-size: 18px;
    font-weight: 700;
    color: #333;
    margin-bottom: 15px;
}

.footer-container .col p {
    font-size: 14px;
    color: #666;
    margin-bottom: 10px;
}

.footer-container .col p strong {
    color: #333;
}

.footer-container .col a {
    color: #666;
    text-decoration: none;
    font-size: 14px;
    display: block;
    margin-bottom: 10px;
}

.footer-container .col a:hover {
    color: #ff6347;
    text-decoration: underline;
}

/* Social Media Icons */
.follow .icon {
    display: flex;
    gap: 10px;
}

.follow .icon a {
    color: #666;
    font-size: 18px;
}

.follow .icon a:hover {
    color: #ff6347;
}

/* App Download Section */
.install .row {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.install .row img {
    width: 120px;
    border-radius: 5px;
}

.install p {
    margin-top: 15px;
    font-size: 14px;
    color: #666;
}

.install .payment {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.install .payment img {
    width: 50px;
}

/* Responsive Design */
@media (max-width: 768px) {
    .seller-dashboard-wrapper {
        flex-direction: column;
    }

    .sidebar {
        width: 100%;
        min-height: auto;
    }

    .main-content {
        padding: 10px;
    }

    .dashboard-container {
        flex-direction: column;
    }

    .add-product-form,
    .product-list {
        flex: 1;
    }

    #product-table th,
    #product-table td {
        font-size: 12px;
    }

    #product-table td img {
        width: 40px;
        height: 40px;
    }

    #navbar li {
        margin-left: 10px;
    }

    .user-info {
        font-size: 14px;
    }

    .hamburger {
        font-size: 18px;
    }

    .footer-container {
        flex-direction: column;
        text-align: center;
    }

    .footer-container .col {
        margin-bottom: 30px;
    }

    .install .row {
        justify-content: center;
    }

    .install .payment {
        justify-content: center;
    }
}

@media (max-width: 480px) {
    .chat-box {
        width: 250px;
    }

    #navbar li {
        margin-left: 5px;
    }

    .user-info {
        font-size: 12px;
    }

    .hamburger {
        font-size: 16px;
    }
}
</style>
