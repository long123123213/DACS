<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Service</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        Order Service
    </header>
    
    <nav>
        <ul>
            <li><a href="#">Trang chủ</a></li>
            <li><a href="#">Đơn hàng của tôi</a></li>
            <li><a href="#">Theo dõi đơn hàng</a></li>
            <li><a href="#">Hỗ trợ</a></li>
        </ul>
    </nav>
    
    <section class="order-list">
        <div class="order">
            <h3>Đơn hàng #12345</h3>
            <p>Trạng thái: Đang xử lý</p>
            <p>Tổng tiền: 500.000 VND</p>
            <button>Xem chi tiết</button>
        </div>
        <div class="order">
            <h3>Đơn hàng #12346</h3>
            <p>Trạng thái: Đang giao</p>
            <p>Tổng tiền: 750.000 VND</p>
            <button>Xem chi tiết</button>
        </div>
        <div class="order">
            <h3>Đơn hàng #12347</h3>
            <p>Trạng thái: Đã giao</p>
            <p>Tổng tiền: 1.200.000 VND</p>
            <button>Xem chi tiết</button>
        </div>
    </section>
    
    
</body>
</html>

